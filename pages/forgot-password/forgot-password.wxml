<scroll-view class="scrollarea" scroll-y type="list">
  <view class="page">
    <view class="back-button" bindtap="goBack">
      <view class="back-icon"></view>
    </view>

    <view class="content">
      <text class="title">Forgot password</text>
      <text class="subtitle">Please enter your email to reset the password</text>

      <view class="field-group">
        <text class="field-label">Your Email</text>
        <view class="field-box">
          <input
            class="field-input"
            type="text"
            value="{{email}}"
            placeholder="Enter your email"
            placeholder-class="field-placeholder"
            bindinput="onEmailInput"
          />
        </view>
      </view>

      <view
        class="primary-button {{canSubmit ? 'primary-button--enabled' : ''}}"
        bindtap="goToVerifyCode"
      >
        Reset Password
      </view>
    </view>
  </view>
</scroll-view>
