page {
  min-height: 100vh;
  background: #ffffff;
}

.page {
  min-height: 100vh;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 26rpx;
  box-sizing: border-box;
}

.success-card {
  width: 100%;
  max-width: 680rpx;
  text-align: center;
  box-sizing: border-box;
}

.title {
  display: block;
  text-align: center;
  font-size: 52rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #1e1e1e;
}

.subtitle-group {
  margin-top: 44rpx;
}

.subtitle {
  display: block;
  text-align: center;
  font-size: 32rpx;
  line-height: 1.55;
  font-weight: 500;
  color: #989898;
}

.primary-button {
  height: 112rpx;
  margin-top: 58rpx;
  border-radius: 24rpx;
  background: #648ddb;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}
