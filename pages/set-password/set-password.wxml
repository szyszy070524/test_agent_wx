<scroll-view class="scrollarea" scroll-y type="list">
  <view class="page">
    <view class="back-button" bindtap="goBack">
      <view class="back-icon"></view>
    </view>

    <view class="content">
      <text class="title">Set a new password</text>

      <view class="subtitle-group">
        <text class="subtitle">Create a new password. Ensure it differs from</text>
        <text class="subtitle">previous ones for security</text>
      </view>

      <view class="field-group">
        <text class="field-label">Password</text>
        <view class="field-box">
          <input
            class="field-input"
            type="text"
            password
            value="{{password}}"
            placeholder="Enter your new password"
            placeholder-class="field-placeholder"
          />
          <text class="field-action">Hide</text>
        </view>
      </view>

      <view class="field-group field-group--compact">
        <text class="field-label">Confirm Password</text>
        <view class="field-box">
          <input
            class="field-input"
            type="text"
            password
            value="{{confirmPassword}}"
            placeholder="Re-enter password"
            placeholder-class="field-placeholder"
          />
          <text class="field-action">Hide</text>
        </view>
      </view>

      <view class="primary-button" bindtap="submitPasswordUpdate">Update Password</view>
    </view>
  </view>
</scroll-view>
